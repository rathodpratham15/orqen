# =============================================================================
# Orqen — Frontend Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# ── Backend API ───────────────────────────────────────────────────────────────
# Local dev: leave empty (Next.js rewrites proxy /api/* to http://localhost:8000)
# Production: set to your Railway backend URL, e.g. https://orqen-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
