# =============================================================================
# Orqen — Backend Environment Variables
# Copy this file to .env and fill in the values marked with <...>
# =============================================================================

# ── Database (Neon) ───────────────────────────────────────────────────────────
# 1. Go to neon.tech → your project → Databases → New Database → name "orqen"
# 2. Go to Connection Details → enable "Pooled connection"
# 3. Copy the connection string and fill in below
#
# DATABASE_URL    → swap postgresql:// → postgresql+asyncpg:// and sslmode=require → ssl=require
# SYNC_DATABASE_URL → use the original string as-is (Alembic uses this)

DATABASE_URL=postgresql+asyncpg://neondb_owner:<password>@<pooler-host>.neon.tech/neondb?ssl=require
SYNC_DATABASE_URL=postgresql://neondb_owner:<password>@<direct-host>.neon.tech/neondb?sslmode=require

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# 1. Go to upstash.com → your database → "Connect" tab
# 2. Copy the rediss:// URL (note: double-s = TLS, required by Upstash)
# 3. Paste the same URL into all three vars below

REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
CELERY_BROKER_URL=rediss://default:<password>@<host>.upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:<password>@<host>.upstash.io:6379

# ── AI ────────────────────────────────────────────────────────────────────────
# anthropic.com → API Keys → Create Key

ANTHROPIC_API_KEY=sk-ant-...

# ── Integrations ──────────────────────────────────────────────────────────────
# resend.com → API Keys → Create Key (free tier: 3k emails/month)

RESEND_API_KEY=re_...

# Slack webhook URLs are configured per-node in the canvas (no global key needed)
# Setup: api.slack.com/apps → New App → Incoming Webhooks → Add to channel → copy URL

# ── App ───────────────────────────────────────────────────────────────────────
# Generate secret key: python3 -c "import secrets; print(secrets.token_hex(32))"

APP_ENV=development
APP_SECRET_KEY=<run: python3 -c "import secrets; print(secrets.token_hex(32))">
CORS_ORIGINS=http://localhost:3000
